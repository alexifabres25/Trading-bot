# ════════════════════════════════════════════════════════
#  BOT AGRESSIF — Altcoins — Risque 2 %
#  Lancement : BOT_CONFIG=.env.aggressive python bot.py
# ════════════════════════════════════════════════════════

BOT_NAME=Bot Agressif

# Binance (testnet.binance.vision pour paper trading)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here
USE_TESTNET=true
DRY_RUN=false

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Capital et risque
CAPITAL=400
RISK_PER_TRADE=0.02    # 2 % → risque max 8 € par trade
STOP_LOSS_PCT=0.025    # Stop-loss à 2.5 % (altcoins plus volatils = plus de marge)

# Altcoins volatils (bougent 5-15 % / jour)
TRADING_PAIRS=SOL/USDT,BNB/USDT,ETH/USDT

# Fichier d'état dédié (ne pas partager avec l'autre bot)
STATE_FILE=state_aggressive.json
