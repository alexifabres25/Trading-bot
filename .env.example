# ─────────────────────────────────────────────────────────
# Binance API
# Pour le testnet : générer les clés sur https://testnet.binance.vision
# Pour le live    : générer les clés sur https://www.binance.com
# ─────────────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here

# true  = testnet Binance (paper trading, sans argent réel) ← recommandé pour débuter
# false = live trading (argent réel !)
USE_TESTNET=true

# true = simulation complète sans connexion exchange (utile pour tester la logique)
DRY_RUN=false

# ─────────────────────────────────────────────────────────
# Telegram
# 1. Crée un bot via @BotFather → récupère le TOKEN
# 2. Envoie un message à ton bot, puis ouvre :
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    → récupère le chat_id dans la réponse
# ─────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─────────────────────────────────────────────────────────
# Capital de départ en USDT
# ─────────────────────────────────────────────────────────
CAPITAL=400
