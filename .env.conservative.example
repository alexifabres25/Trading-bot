# ════════════════════════════════════════════════════════
#  BOT CONSERVATEUR — BTC/USDT — Risque 1 %
#  Lancement : BOT_CONFIG=.env.conservative python bot.py
# ════════════════════════════════════════════════════════

BOT_NAME=Bot Conservateur

# Binance (testnet.binance.vision pour paper trading)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here
USE_TESTNET=true
DRY_RUN=false

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Capital et risque
CAPITAL=400
RISK_PER_TRADE=0.01    # 1 % → risque max 4 € par trade
STOP_LOSS_PCT=0.02     # Stop-loss à 2 % sous l'entrée

# Paires
TRADING_PAIRS=BTC/USDT

# Fichier d'état dédié (ne pas partager avec l'autre bot)
STATE_FILE=state_conservative.json
